export async function GET() {
  try {
    await connectToStationDatabase();
    const currentDb = mongoose.connection.name;
    console.log(`📡 連線資料庫: ${currentDb}`);

    const cleanedData = jsonData.stations.map((s: any) => {
      //   if (s.line && !Array.isArray(s.line)) {
      //     console.log(`🔍 發現格式不一致的車站: ${s.name} (ID: ${s.id})`);
      //   }
      const idStr = s.id.toString();
      const paths = photoPaths[idStr] || [];
      const notes = photoNotes[idStr] || [];

      // ✨ 圖片縫合與日期解析邏輯
      const images = paths.map((url, index) => {
        const fullNote = notes[index] || "";

        // 正則表達式：尋找結尾的 YYYY.MM.DD (例如 2024.03.20)
        const dateMatch = fullNote.match(/(\d{4}\.\d{1,2}\.\d{1,2})$/);
        const capturedAt = dateMatch
          ? new Date(dateMatch[1].replace(/\./g, "-"))
          : undefined;

        // 移除敘述中的日期部分，保持描述乾淨
        const description = fullNote
          .replace(/\s?\d{4}\.\d{1,2}\.\d{1,2}$/, "")
          .trim();

        return {
          url,
          description,
          capturedAt: capturedAt || new Date(),
        };
      });

      const lineArray = Array.isArray(s.line) ? s.line : s.line ? [s.line] : [];

      const processedLine = lineArray.map((l: any) => {
        // ✨ 核心修正：判斷 lineDistrict 是陣列還是單一物件
        let districts = [];

        if (Array.isArray(l.lineDistrict)) {
          // 情況 A: 虎尾站那種陣列格式 [ {id:1, order:5}, {id:2, order:1} ]
          districts = l.lineDistrict.map((d: any) => ({
            id: Number(d.id || 0),
            order: Number(d.order || 0),
          }));
        } else if (l.lineDistrict && typeof l.lineDistrict === "object") {
          // 情況 B: 一般車站的單一物件格式 {id:1, order:1}
          districts = [
            {
              id: Number(l.lineDistrict.id || 0),
              order: Number(l.lineDistrict.order || 0),
            },
          ];
        } else if (typeof l.lineDistrict === "number") {
          // 情況 C: 極端情況，只有一個數字 (ID)
          districts = [{ id: l.lineDistrict, order: 0 }];
        }

        return {
          lineID: Number(l.lineID),
          // 💡 這裡回傳的是陣列，對應 Schema 改成 [lineDistrictSchema]
          lineDistrict: districts,
        };
      });

      return {
        id: Number(s.id),
        name: s.name,
        status: s.status || "active",
        openDate: s.openDate || "",
        closeDate: s.closeDate || "",
        originalName: s.originalName || "",
        level: s.level || "",
        miles: s.miles || "",
        height: s.height || "",
        stationCode: s.stationCode || "",
        line: processedLine,
        prevStation: Array.isArray(s.prevStation)
          ? s.prevStation.map(Number)
          : s.prevStation
            ? [Number(s.prevStation)]
            : [],
        nextStation: Array.isArray(s.nextStation)
          ? s.nextStation.map(Number)
          : s.nextStation
            ? [Number(s.nextStation)]
            : [],
        hasDetail: s.hasDetail !== undefined ? s.hasDetail : true,
        images: images, // 💡 注入處理好的圖片陣列
      };
    });

    console.log(`🚀 準備匯入 ${cleanedData.length} 筆車站資料 (含圖片)...`);

    await Station.deleteMany({});
    const result = await Station.insertMany(cleanedData);

    return NextResponse.json({
      message: "🎉 車站資料（含圖片解析）遷移成功！",
      database: currentDb,
      count: result.length,
      sample: result[0]?.images, // 回傳第一筆資料的圖片檢查看看
    });
  } catch (error: any) {
    console.error("❌ 遷移失敗:", error);
    return NextResponse.json(
      { error: "遷移失敗", details: error.message },
      { status: 500 },
    );
  }
}
